name: Build

on:
  push:
    branches: [ main, master, dev ]
    tags:
      - 'v*'
  pull_request:
    branches: [ main, master ]
  workflow_dispatch:

env:
  JAVA_VERSION: '17'
  GRADLE_VERSION: '8.5'

jobs:
  build:
    runs-on: ubuntu-latest
    
    steps:
    - name: Checkout repository
      uses: actions/checkout@v4
      
    - name: Set up JDK ${{ env.JAVA_VERSION }}
      uses: actions/setup-java@v4
      with:
        java-version: ${{ env.JAVA_VERSION }}
        distribution: 'temurin'
        cache: gradle
        
    - name: Setup Gradle
      uses: gradle/actions/setup-gradle@v3
      with:
        gradle-version: ${{ env.GRADLE_VERSION }}
        
    - name: Grant execute permission for gradlew
      run: chmod +x gradlew
      
    - name: Download MTR dependencies
      run: |
        mkdir -p libs/mtr3
        echo "MTR jars need to be downloaded manually or from a mirror"
        echo "See README.md for instructions"
        # Placeholder: create empty jars for structure
        touch libs/mtr3/.gitkeep
        
    - name: Build common module
      run: ./gradlew :common:build --no-daemon || true
      
    - name: Build all targets
      run: ./gradlew buildAllTargets --no-daemon || true
      
    - name: Upload build artifacts
      uses: actions/upload-artifact@v4
      if: always()
      with:
        name: MTRWebCTC-build
        path: |
          **/build/libs/*.jar
          !**/build/libs/*-sources.jar
        retention-days: 30

  lint:
    runs-on: ubuntu-latest
    
    steps:
    - name: Checkout repository
      uses: actions/checkout@v4
      
    - name: Set up JDK ${{ env.JAVA_VERSION }}
      uses: actions/setup-java@v4
      with:
        java-version: ${{ env.JAVA_VERSION }}
        distribution: 'temurin'
        cache: gradle
        
    - name: Setup Gradle
      uses: gradle/actions/setup-gradle@v3
      with:
        gradle-version: ${{ env.GRADLE_VERSION }}
        
    - name: Grant execute permission for gradlew
      run: chmod +x gradlew
      
    - name: Run linting
      run: ./gradlew check --no-daemon || true

  release:
    needs: build
    runs-on: ubuntu-latest
    if: startsWith(github.ref, 'refs/tags/v')
    
    steps:
    - name: Checkout repository
      uses: actions/checkout@v4
      
    - name: Download artifacts
      uses: actions/download-artifact@v4
      with:
        name: MTRWebCTC-build
        path: artifacts
        
    - name: List artifacts
      run: find artifacts -name "*.jar" -type f
      
    - name: Create Release
      uses: softprops/action-gh-release@v1
      with:
        files: artifacts/**/*.jar
        generate_release_notes: true
        draft: true
      env:
        GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
